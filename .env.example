# ─────────────────────────────────────────────────────────────────────────────
# SoloEdge Suite — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
VITE_APP_ID=soloedge
NODE_ENV=production
APP_BASE_URL=https://soloedge.app          # Public base URL — used to build Twilio webhook + dashboard links

# ── Auth / Database ───────────────────────────────────────────────────────────
JWT_SECRET=                                # Long random string for cookie signing
DATABASE_URL=                              # MySQL / TiDB connection string
OAUTH_SERVER_URL=                          # Manus OAuth server URL
OWNER_OPEN_ID=                             # Your OAuth openId (grants admin role)

# ── Forge (LLM / AI) ─────────────────────────────────────────────────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=                        # AC...
TWILIO_AUTH_TOKEN=                         # Auth token from Twilio console
TWILIO_SMS_FROM=                           # SoloEdge outbound SMS number e.g. +17372595692

# ── SendGrid ──────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=                          # SG.xxx — transactional email for welcome messages
FROM_EMAIL=riley@soloedge.app              # Verified sender address in SendGrid

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...              # Use sk_test_ until go-live
STRIPE_WEBHOOK_SECRET=whsec_...           # From Stripe Dashboard → Webhooks

# ── Telegram (owner alerts) ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                        # From @BotFather
TELEGRAM_ALERT_CHAT_ID=                    # Your personal chat ID or group ID

# ── Google Calendar OAuth ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://soloedge.app/api/google/callback
